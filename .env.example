# Production Environment Variables
# Copy this file to .env and update values

# Admin credentials (CHANGE THESE IN PRODUCTION)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password_here

# Flask secret key (GENERATE A NEW ONE FOR PRODUCTION)
SECRET_KEY=your_secret_key_here

# WhatsApp number for orders
WHATSAPP_NUMBER=+2348033939180

# Email configuration for order notifications
# (optional - if not set, order notifications will only go to WhatsApp)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_USE_TLS=true
ADMIN_EMAIL=admin@example.com

# Database path (optional, defaults to instance/coco_store.db)
DATABASE_PATH=/path/to/database.db

# Flask environment
FLASK_ENV=production
